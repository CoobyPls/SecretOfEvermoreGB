      "command": "EVENT_GBVM_SCRIPT",
      "id": "codex-menu-hud-gbvm-redraw",
      "args": {
        "script": "VM_LOAD_TEXT 8\n.dw VAR_PLAYERHP\n.dw VAR_PLAYERMAXHP\n.dw VAR_EQUIPPEDAICON\n.dw VAR_EQUIPPEDBICON\n.dw VAR_MENUTALONICON\n.dw VAR_PLAYERTALONS\n.dw VAR_MENUPETALICON\n.dw VAR_ITEMNUMPETAL\n.asciz \"\\002\\002\\003\\001\\001HP %D2/%D2\\003\\016\\001%c\\003\\022\\001%c\\003\\016\\004%c%D3\\003\\006\\011%c%D2\"\nVM_DISPLAY_TEXT",
