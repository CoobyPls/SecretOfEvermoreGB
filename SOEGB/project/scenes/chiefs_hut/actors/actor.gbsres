      "children": {
        "true": [
          {
            "command": "EVENT_TEXT",
            "args": {
              "text": [
                "Well I'll be!\nAn outsider! At a\ntime like this?",
                "Wait, I know those\neyes! Elizabeth\ngrew up, it seems!",
                "What a pleasant\nsurprise! However\nyour timimg...",
                "It could not have\nbeen any worse had\nyou scripted it!"
              ],
              "__section": "text",
              "avatarId": "",
              "minHeight": 5,
              "maxHeight": 7,
              "textX": 1,
              "textY": 1,
              "textHeight": 5,
